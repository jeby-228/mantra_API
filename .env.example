# PostgreSQL 資料庫連線設定
# 格式: postgres://使用者:密碼@主機:埠/資料庫名稱?sslmode=disable
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/mantra_api?sslmode=disable

# JWT 密鑰 (生產環境請使用強隨機字串)
# 建議使用 openssl rand -base64 32 生成
JWT_SECRET=your-very-secret-key-change-in-production

# Watchtower Configuration
WATCHTOWER_CLEANUP=true
WATCHTOWER_POLL_INTERVAL=300
WATCHTOWER_LABEL_ENABLE=true
WATCHTOWER_INCLUDE_RESTARTING=true

# 應用程式監聽埠 (本地開發用，Docker/CD 環境會覆蓋)
PORT=8080

# CORS 允許的前端來源（多個來源用逗號分隔，不加空格）
# 本地開發預設允許 http://localhost:5173 和 http://localhost:4173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173

# LINE Login 配置
# 從 LINE Developers Console 獲取
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
